ALPACA_API_KEY=your_alpaca_api_key
ALPACA_API_SECRET=your_alpaca_api_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# Comma-separated symbols to scan each run
SYMBOLS=SOL/USD

BAR_TIMEFRAME=1Min
LOOKBACK_BARS=240
FAST_EMA=5
SLOW_EMA=13
RSI_PERIOD=7
RSI_OVERBOUGHT=75
RSI_OVERSOLD=30
MIN_CONFIDENCE=0.20

# Risk controls
MAX_NOTIONAL_PER_POSITION=0.10
MAX_POSITIONS=2
STOP_LOSS_PCT=0.008
TAKE_PROFIT_PCT=0.016
COOLDOWN_MINUTES=20

# Safety: keep TRUE until you are ready to place real paper orders
DRY_RUN=false
ORDER_TIME_IN_FORCE=day
POLL_INTERVAL_SECONDS=120
