ALPACA_API_KEY=your_alpaca_api_key
ALPACA_API_SECRET=your_alpaca_api_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# Comma-separated symbols to scan each run
SYMBOLS=SOL/USD

BAR_TIMEFRAME=5Min
LOOKBACK_BARS=300
FAST_EMA=8
SLOW_EMA=13
RSI_PERIOD=10
RSI_OVERBOUGHT=75
RSI_OVERSOLD=30
MIN_CONFIDENCE=0.25

# Volume spike filter (proxy for institutional activity)
VOLUME_LOOKBACK=20
VOLUME_SPIKE_MULTIPLIER=1.5
GAP_THRESHOLD=0.0015
MIN_BODY_PCT=0.0015

# Backtest/optimizer extras
RANDOM_WINDOW=true
WINDOW_DAYS=90
WINDOW_YEARS=2
RANDOM_SEED=
SLIPPAGE_BPS=5       # 0.05% per side assumed slippage in backtest
FEE_PCT=0.0005       # 0.05% per side fee assumption in backtest

# Risk controls
MAX_NOTIONAL_PER_POSITION=0.20
MAX_POSITIONS=3
STOP_LOSS_PCT=0.0075
TAKE_PROFIT_PCT=0.012
COOLDOWN_MINUTES=3

# Safety: keep TRUE until you are ready to place real paper orders
DRY_RUN=false
ORDER_TIME_IN_FORCE=day
POLL_INTERVAL_SECONDS=60
