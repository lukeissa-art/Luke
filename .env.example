ALPACA_API_KEY=your_alpaca_api_key
ALPACA_API_SECRET=your_alpaca_api_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# Comma-separated symbols to scan each run
SYMBOLS=SOL/USD

BAR_TIMEFRAME=5Min
LOOKBACK_BARS=300
FAST_EMA=8
SLOW_EMA=13
RSI_PERIOD=10
RSI_OVERBOUGHT=75
RSI_OVERSOLD=30
MIN_CONFIDENCE=0.35

# Risk controls
MAX_NOTIONAL_PER_POSITION=0.10
MAX_POSITIONS=3
STOP_LOSS_PCT=0.0075
TAKE_PROFIT_PCT=0.012
COOLDOWN_MINUTES=5

# Safety: keep TRUE until you are ready to place real paper orders
DRY_RUN=false
ORDER_TIME_IN_FORCE=day
POLL_INTERVAL_SECONDS=60
